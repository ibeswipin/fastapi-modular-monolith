# Copy to .env and adjust for your machine. Every value here maps 1:1 to a
# field in app/core/config.py:Settings — see that file for defaults and docs.

PROJECT_NAME="Users API"
ENVIRONMENT=development

# postgresql+asyncpg://user:password@host:port/db_name
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/users_api

# Generate a real secret for anything beyond local dev, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

VERIFICATION_CODE_EXPIRE_MINUTES=15
UNVERIFIED_USER_RETENTION_DAYS=2

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CLEANUP_SCHEDULE_MINUTES=60

REDIS_URL=redis://localhost:6379/2

MAX_LOGIN_FAILURES=5
LOGIN_LOCKOUT_MINUTES=15
